{
  "name": "ecom",
  "version": "1.0.0",
  "description": "ecommerce rest api",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm start --prefix ./client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "sonarqube": "sonar-scanner",
    "test": "npm run test:backend && npm run test:frontend",
    "test:frontend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.frontend.config.js",
    "test:backend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.backend.config.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:ui": "npx playwright test",
    "seed:loadtest": "node scripts/seedLoadTestData.js",
    "load:story1": "k6 run nft/load-testing/story1_authentication.load.test.js",
    "load:story2": "k6 run nft/load-testing/story2_product_browsing.load.test.js",
    "load:story3": "k6 run nft/load-testing/Shauryan_A0265846N/story3_category_management.load.test.js",
    "load:story4": "k6 run nft/load-testing/Shauryan_A0265846N/story4_profile_orders.load.test.js",
    "load:story5": "k6 run nft/load-testing/Shauryan_A0265846N/story5_mixed_workload.load.test.js",
    "load:payment": "k6 run nft/load-testing/Shauryan_A0265846N/story_payment_checkout.load.test.js",
    "load:photo": "k6 run nft/load-testing/Shauryan_A0265846N/story_photo_retrieval.load.test.js",
    "load:resource": "k6 run nft/load-testing/story_resource_stability.load.test.js",
    "cleanup:categories": "node scripts/cleanupLoadTestCategories.js"

  },
  "keywords": [],
  "author": "RP",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "braintree": "^3.22.0",
    "colors": "^1.4.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-formidable": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "mongoose": "^8.1.2",
    "morgan": "^1.10.0",
    "nodemon": "^3.0.3",
    "react-icons": "^5.0.1",
    "slugify": "^1.6.6",
    "supertest": "^7.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.1",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.12.12",
    "babel-jest": "^29.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.2.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "sonarqube-scanner": "^4.3.5",
    "supertest": "^7.2.2"
  }
}
